          { text: "Activo el sistema.", points: { "Arquitecto del Orden": 1 }, glitch: "El sistema te etiqueta como perfil inestable por buscar ideas políticas alternativas.", follow: [
            { text: "Acepto el control por seguridad.", points: { "Arquitecto del Orden": 3 } },
            { text: "Prefiero recuperar libertad.", points: { "Insurrecto": 3 } }
          ]},
          { text: "Lo rechazo.", points: { "Insurrecto": 1 }, glitch: "Sufrís un robo violento que podría haberse evitado con vigilancia predictiva.", follow: [
            { text: "La privacidad vale el riesgo.", points: { "Insurrecto": 3 } },
            { text: "Acepto el sistema.", points: { "Arquitecto del Orden": 3 } }
          ]}
        ]
      },
      {
        title: "La Matrix de las Certezas",
        dilemma: "Un buscador ofrece ‘la verdad objetiva’ sobre cualquier hecho político o histórico, eliminando fake news.",
        options: [
          { text: "Uso el buscador.", points: { "Arquitecto del Orden": 1 }, glitch: "Descubrís que el algoritmo favorece los intereses de las corporaciones que lo diseñaron.", follow: [
            { text: "Sostengo el oráculo.", points: { "Arquitecto del Orden": 2, "Navegante de la Matrix": 1 } },
            { text: "Dejo de usarlo.", points: { "Insurrecto": 3 } }
          ]},
          { text: "Lo rechazo.", points: { "Insurrecto": 1 }, glitch: "La sociedad se fragmenta tanto que ya nadie comparte una realidad básica.", follow: [
            { text: "Prefiero pluralidad aunque sea incómoda.", points: { "Insurrecto": 2, "Humano Irreductible": 1 } },
            { text: "Hace falta una verdad común.", points: { "Arquitecto del Orden": 3 } }
          ]}
        ]
      },
      {
        title: "El Cerebro de Silicio",
        dilemma: "Te ofrecen subir tu mente a un servidor digital antes de morir. Tu conciencia seguiría viva en un entorno virtual.",
        options: [
          { text: "Subo mi mente.", points: { "Navegante de la Matrix": 1 }, glitch: "La empresa cambia los términos y condiciones. Sin suscripción premium, tu pensamiento funciona más lento y con publicidad.", follow: [
            { text: "Sigo en el servidor.", points: { "Navegante de la Matrix": 3 } },
            { text: "Eso no era vida humana.", points: { "Humano Irreductible": 3 } }
          ]},
          { text: "Rechazo el upload.", points: { "Humano Irreductible": 1 }, glitch: "En tus últimos momentos, tus amigos digitalizados siguen creando, hablando y viviendo en la red.", follow: [
            { text: "Sin cuerpo no soy yo.", points: { "Humano Irreductible": 3 } },
            { text: "Aceptaría digitalizarme.", points: { "Navegante de la Matrix": 3 } }
          ]}
        ]
      },
      {
        title: "La Economía del Silencio",
        dilemma: "Una app te paga un sueldo básico mensual en dólares si pasás 4 horas al día en una habitación blanca, sin estímulos.",
        options: [
          { text: "Acepto el trato.", points: { "Humano Irreductible": 1 }, glitch: "El silencio empieza a enfrentarte con pensamientos oscuros que antes tapabas con ruido.", follow: [
            { text: "Sigo entrando.", points: { "Forjador": 2, "Humano Irreductible": 1 } },
            { text: "Salgo del programa.", points: { "Navegante de la Matrix": 3 } }
          ]},
          { text: "Lo rechazo.", points: { "Insurrecto": 1 }, glitch: "Seguís hiperestimulado, sin plata y cada vez más disperso.", follow: [
            { text: "Mi tiempo no se vende.", points: { "Insurrecto": 2, "Estratega": 1 } },
            { text: "Acepto el trato.", points: { "Humano Irreductible": 3 } }
          ]}
        ]
      }
    ];

    const state = {
      selected: [],
      index: 0,
      scores: Object.keys(profiles).reduce((acc, p) => { acc[p] = 0; return acc; }, {})
    };

    function shuffle(array) {
      return [...array].sort(() => Math.random() - 0.5);
    }

    function addPoints(points) {
      for (const [profile, value] of Object.entries(points)) {
        state.scores[profile] = (state.scores[profile] || 0) + value;
      }
    }

    function progressPercent() {
      return Math.round((state.index / 3) * 100);
    }

    function renderProgress() {
      return `<div class="progress"><div class="progress-bar" style="width:${progressPercent()}%"></div></div>`;
    }

    function startGame() {
      state.selected = shuffle(scenarios).slice(0, 3);
      state.index = 0;
      for (const p of Object.keys(state.scores)) state.scores[p] = 0;
      renderScenario();
    }

    function renderStart() {
      document.getElementById("screen").innerHTML = `
        <h1>Sistema<br>Glitcheado</h1>
        <p class="subtitle">Bienvenido a <strong>EXPO UCALP</strong>.<br><br>
        Este sistema va a ponerte frente a <strong>3 dilemas filosóficos</strong>.
        No hay respuestas correctas. Pero sí hay respuestas que muestran cómo pensás cuando una certeza empieza a fallar.</p>
        <div class="meta">Escaneá · Elegí · Sostené</div>
        <div class="buttons">
          <button class="primary" onclick="startGame()">INICIAR DIAGNÓSTICO FILOSÓFICO</button>
        </div>
      `;
    }

    function renderScenario() {
      const s = state.selected[state.index];
      document.getElementById("screen").innerHTML = `
        ${renderProgress()}
        <div class="scenario-title">Escenario ${state.index + 1} de 3 · ${s.title}</div>
        <h2>${s.title}</h2>
        <p class="question">${s.dilemma}</p>
        <div class="buttons">
          ${s.options.map((opt, i) => `<button onclick="chooseInitial(${i})">${opt.text}</button>`).join("")}
        </div>
      `;
    }

    function chooseInitial(optionIndex) {
      const s = state.selected[state.index];
      const opt = s.options[optionIndex];
      addPoints(opt.points);
      renderGlitch(opt);
    }

    function renderGlitch(opt) {
      document.getElementById("screen").innerHTML = `
        ${renderProgress()}
        <div class="glitch-box">
          <div class="glitch-label">ERROR_DE_SISTEMA // CONTRADICCIÓN DETECTADA</div>
          <div class="terminal">SISTEMA_ANALIZANDO...
██████████░░░░░░
ERROR 0xUCALP-404
TU RESPUESTA FUNCIONA EN TEORÍA.
AHORA PROBALA EN LA VIDA REAL.</div>
          <p class="question">${opt.glitch}</p>
        </div>
        <div class="buttons">
          ${opt.follow.map((f, i) => `<button onclick="chooseFollow(${JSON.stringify(f.points).replace(/"/g, '&quot;')})">${f.text}</button>`).join("")}
        </div>
      `;
    }

    function chooseFollow(points) {
      addPoints(points);
      state.index += 1;
      if (state.index >= 3) renderResult();
      else renderScenario();
    }

    function getRankedScores() {
      return Object.entries(state.scores).sort((a, b) => b[1] - a[1]);
    }

    function renderResult() {
      const ranked = getRankedScores();
      const main = ranked[0][0];
      const shadow = ranked[1][0];
      const max = Math.max(...ranked.map(r => r[1]), 1);
      const p = profiles[main];
      const total = ranked.reduce((sum, item) => sum + item[1], 0) || 1;
      const affinity = Math.round((ranked[0][1] / total) * 100);
      const rarity = 8 + ((main.length * 7 + shadow.length * 3 + state.selected[0].title.length) % 19);

      document.getElementById("screen").innerHTML = `
        <div class="meta">SISTEMA_FINALIZADO.EXE</div>
        <h2>Análisis completado</h2>
        <div class="result-card">
          <div class="small">Carnet filosófico de Expo UCALP</div>
          <div class="capture-card">
            <div class="small">PERFIL DETECTADO</div>
            <div class="profile-name">${p.title}</div>
            <p class="final-text"><strong>${p.phrase}</strong></p>
            <div class="result-topline">
              <span class="mini-chip">Afinidad: ${affinity}%</span>
              <span class="mini-chip">Perfil sombra: ${shadow}</span>
              <span class="mini-chip">Frecuencia estimada: ${rarity}%</span>
            </div>
            <div class="barcode"></div>
          </div>
          <p class="final-text">${p.text}</p>
          <p class="small">Inspiración filosófica: ${p.inspiration}</p>
        </div>

        <p class="final-text">Vivimos rodeados de respuestas:<br>
        las de las redes,<br>
        las de los algoritmos,<br>
        las de nuestro grupo,<br>
        las de nuestra época.</p>

        <p class="final-text">La filosofía no ofrece respuestas automáticas.</p>
        <p class="final-text">Su tarea consiste en formular preguntas capaces de ponerlas en cuestión.</p>

        <div class="score-list">
          ${ranked.map(([name, score]) => `
            <div class="score-row">
              <div>${name}</div>
              <div class="score-track"><div class="score-fill" style="width:${Math.round((score / max) * 100)}%"></div></div>
              <div>${score}</div>
            </div>
          `).join("")}
        </div>

        <div class="buttons">
          <a class="link-button primary" href="https://www.ucalp.edu.ar/carrera/filosofiadistancia/" target="_blank" rel="noopener noreferrer">ESTUDIAR FILOSOFÍA EN UCALP</a>
          <button onclick="renderStart()">REINICIAR SISTEMA</button>
        </div>
        <p class="qr-note">Para la Expo: subí este archivo a una URL pública y usá esa dirección para el QR del stand.</p>
      `;
    }

    renderStart();
  </script>
</body>
</html>
