
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EXPO UCALP | Sistema Glitcheado V2</title>
  <style>
    :root {
      --bg: #070711;
      --panel: rgba(17, 18, 38, 0.88);
      --text: #f4f7ff;
      --muted: #a8b0c8;
      --cyan: #00f0ff;
      --pink: #ff2bd6;
      --green: #39ff88;
      --yellow: #fff04a;
      --red: #ff3b5f;
      --border: rgba(0, 240, 255, 0.35);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(255, 43, 214, 0.22), transparent 30%),
        radial-gradient(circle at bottom right, rgba(0, 240, 255, 0.22), transparent 35%),
        linear-gradient(135deg, #050509, #09091a 55%, #120622);
      color: var(--text);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 18px;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background: repeating-linear-gradient(
        to bottom,
        rgba(255,255,255,0.025) 0px,
        rgba(255,255,255,0.025) 1px,
        transparent 2px,
        transparent 5px
      );
      mix-blend-mode: overlay;
    }

    .app {
      width: min(920px, 100%);
      min-height: 620px;
      border: 1px solid var(--border);
      border-radius: 26px;
      background: var(--panel);
      box-shadow: 0 0 36px rgba(0, 240, 255, 0.12), 0 0 80px rgba(255, 43, 214, 0.08);
      padding: clamp(22px, 4vw, 42px);
      position: relative;
      overflow: hidden;
    }

    .app::after {
      content: "EXPO UCALP // SISTEMA GLICHEADO // EXPO UCALP //";
      position: absolute;
      left: -5%;
      bottom: 16px;
      width: 110%;
      color: rgba(255,255,255,0.055);
      font-size: 13px;
      letter-spacing: 4px;
      white-space: nowrap;
      transform: rotate(-1deg);
      pointer-events: none;
    }

    .brand {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 28px;
      color: var(--cyan);
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 800;
      font-size: 13px;
    }

    .badge {
      border: 1px solid rgba(57, 255, 136, 0.45);
      color: var(--green);
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 11px;
    }

    h1, h2, h3 { margin: 0; }

    h1 {
      font-size: clamp(36px, 7vw, 68px);
      line-height: 0.92;
      text-transform: uppercase;
      letter-spacing: -2px;
      text-shadow: 2px 0 var(--pink), -2px 0 var(--cyan);
      margin-bottom: 18px;
    }

    h2 {
      font-size: clamp(25px, 4vw, 42px);
      line-height: 1.05;
      margin-bottom: 18px;
      color: #fff;
    }

    .subtitle {
      color: var(--muted);
      max-width: 720px;
      font-size: clamp(17px, 2vw, 21px);
      line-height: 1.55;
      margin-bottom: 26px;
    }

    .meta {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      color: var(--yellow);
      border: 1px solid rgba(255, 240, 74, 0.35);
      border-radius: 14px;
      padding: 9px 12px;
      margin-bottom: 18px;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .scenario-title {
      color: var(--cyan);
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 12px;
    }

    .question {
      font-size: clamp(19px, 2.5vw, 26px);
      line-height: 1.35;
      margin-bottom: 24px;
    }

    .buttons {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
      margin-top: 24px;
      position: relative;
      z-index: 2;
    }

    button, .link-button {
      border: 1px solid rgba(0, 240, 255, 0.42);
      background: rgba(0, 240, 255, 0.08);
      color: var(--text);
      padding: 18px 18px;
      border-radius: 18px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      text-align: left;
      transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
      text-decoration: none;
      display: block;
    }

    button:hover, .link-button:hover {
      transform: translateY(-2px);
      background: rgba(255, 43, 214, 0.14);
      border-color: rgba(255, 43, 214, 0.72);
    }

    .primary {
      text-align: center;
      background: linear-gradient(90deg, rgba(0, 240, 255, 0.20), rgba(255, 43, 214, 0.20));
      border-color: rgba(57, 255, 136, 0.55);
    }

    .progress {
      height: 8px;
      width: 100%;
      border-radius: 99px;
      background: rgba(255,255,255,0.08);
      overflow: hidden;
      margin-bottom: 26px;
    }

    .progress-bar {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, var(--cyan), var(--pink));
      transition: width 0.4s ease;
    }

    .glitch-box {
      border: 1px solid rgba(255, 59, 95, 0.55);
      background: rgba(255, 59, 95, 0.08);
      border-radius: 22px;
      padding: 20px;
      margin-bottom: 22px;
      box-shadow: inset 0 0 24px rgba(255, 59, 95, 0.10);
    }

    .glitch-label {
      color: var(--red);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 12px;
      animation: jitter 0.8s infinite;
    }

    @keyframes jitter {
      0%, 100% { transform: translate(0); }
      20% { transform: translate(-1px, 1px); }
      40% { transform: translate(1px, -1px); }
      60% { transform: translate(-1px, -1px); }
      80% { transform: translate(1px, 1px); }
    }

    .result-card {
      border: 1px solid rgba(57, 255, 136, 0.40);
      background: rgba(57, 255, 136, 0.06);
      padding: 22px;
      border-radius: 24px;
      margin: 20px 0;
    }

    .profile-name {
      font-size: clamp(30px, 5vw, 54px);
      line-height: 1;
      color: var(--green);
      text-transform: uppercase;
      text-shadow: 2px 0 rgba(255, 43, 214, 0.75);
      margin: 10px 0 14px;
    }

    .shadow-profile {
      color: var(--yellow);
      font-weight: 800;
      margin-top: 12px;
    }

    .small {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .final-text {
      color: var(--text);
      line-height: 1.65;
      font-size: 17px;
      margin: 18px 0;
    }

    .score-list {
      display: grid;
      gap: 8px;
      margin-top: 16px;
    }

    .score-row {
      display: grid;
      grid-template-columns: 190px 1fr 38px;
      gap: 10px;
      align-items: center;
      color: var(--muted);
      font-size: 13px;
    }

    .score-track {
      height: 8px;
      background: rgba(255,255,255,0.08);
      border-radius: 99px;
      overflow: hidden;
    }

    .score-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--cyan), var(--pink));
    }



    .terminal {
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(0,0,0,0.28);
      border-radius: 16px;
      padding: 14px;
      margin: 0 0 18px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      color: var(--green);
      font-size: 13px;
      line-height: 1.6;
      box-shadow: inset 0 0 20px rgba(0, 240, 255, 0.07);
      white-space: pre-line;
    }

    .result-topline {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 14px 0 0;
    }

    .mini-chip {
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.06);
      border-radius: 999px;
      padding: 8px 11px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }

    .capture-card {
      border: 1px solid rgba(0, 240, 255, 0.48);
      background:
        linear-gradient(135deg, rgba(0, 240, 255, 0.10), transparent 35%),
        linear-gradient(315deg, rgba(255, 43, 214, 0.10), transparent 35%),
        rgba(255,255,255,0.035);
      padding: 20px;
      border-radius: 22px;
      margin-top: 16px;
    }

    .barcode {
      margin-top: 14px;
      height: 36px;
      opacity: 0.8;
      background: repeating-linear-gradient(90deg, rgba(255,255,255,0.9) 0 2px, transparent 2px 6px, rgba(255,255,255,0.55) 6px 9px, transparent 9px 13px);
      border-radius: 4px;
    }

    .qr-note {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
      margin-top: 12px;
    }

    @media (max-width: 620px) {
      .app { min-height: auto; border-radius: 20px; }
      .brand { align-items: flex-start; flex-direction: column; }
      .score-row { grid-template-columns: 1fr; gap: 5px; }
      button { font-size: 15px; padding: 16px; }
    }
  </style>
</head>
